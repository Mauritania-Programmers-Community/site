{
  "name": "mpc-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"velite dev\" \"next dev --turbopack\"",
    "dev:next": "next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "velite && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test scripts/__tests__/*.test.mjs",
    "create:post": "node scripts/create-content.mjs post",
    "create:event": "node scripts/create-content.mjs event",
    "content:check": "node scripts/content-check.mjs",
    "content:status": "node scripts/content-status.mjs",
    "content:publish": "node scripts/content-publish.mjs",
    "content:unpublish": "node scripts/content-publish.mjs --unpublish",
    "optimize:images": "node scripts/optimize-images.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^0.6.5",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "ics": "^3.12.0",
    "lightningcss": "^1.32.0",
    "lucide-react": "^0.555.0",
    "motion": "^12.42.2",
    "next": "16.1.1",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-use-measure": "^2.1.7",
    "rough-notation": "^0.5.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.181.2",
    "tw-animate-css": "^1.4.0"
  },
  "browserslist": [
    "defaults and supports es6-module",
    "maintained node versions"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.41",
    "concurrently": "^9.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.0.5",
    "husky": "^9.1.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.34.5",
    "shiki": "^3.23.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "velite": "^0.3.1"
  }
