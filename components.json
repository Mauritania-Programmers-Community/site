{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "src/app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@magicui": {
      "url": "https://magicui.design/r/{name}.json"
    },
    "@kokonutui": {
      "url": "https://kokonut-ui.vercel.app/r/{name}.json"
    },
    "@originui": {
      "url": "https://originui.com/r/{name}.json"
    },
    "@aceternity": {
      "url": "https://ui.aceternity.com/registry/{name}.json"
    },
    "@motion-primitives": {
      "url": "https://motion-primitives.com/c/{name}.json"
    },
    "@hextaui": {
      "url": "https://hextaui.com/r/{name}.json"
    },
    "@cult-ui": {
      "url": "https://cult-ui.com/r/{name}.json"
    },
    "@tailark": "https://tailark.com/r/{name}.json"
  }
}
